MONGO_URI=mongodb://localhost:27017/souldex
JWT_SECRET=your_jwt_secret_here
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
ALLOWED_ORIGINS=http://localhost:5173

# Email (SMTP) - for Gmail use App Password (enable 2-Step Verification first)
# For Gmail SMTP set EMAIL_USER to your Gmail address and EMAIL_PASS to the app password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
# set to true if using port 465 (SSL), false for 587 (STARTTLS)
EMAIL_SECURE=false
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM="SoulDex <your.email@gmail.com>"

# Optional: Resend API key. If set, the server will use Resend for transactional email.
RESEND_API_KEY=

# Base URL used in email links (verification / reset)
EMAIL_BASE_URL=http://localhost:5173
